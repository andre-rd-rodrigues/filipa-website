# Sanity
# Find these in https://manage.sanity.io (Project settings / API).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
# Optional: server-only token for reading drafts / preview (never expose to the client).
SANITY_API_READ_TOKEN=

# Google Analytics
# GA4 Measurement ID, e.g. G-XXXXXXXXXX. GA only loads after cookie consent.
NEXT_PUBLIC_GA_ID=

# Formspree
# Form ID from https://formspree.io (the part after /f/ in your endpoint URL).
NEXT_PUBLIC_FORMSPREE_ID=

# Kit (formerly ConvertKit) — newsletter subscriptions via the V4 API.
# Server-only: never expose these with a NEXT_PUBLIC_ prefix.
# Create a V4 API key in Kit → Account settings → Developer tab.
KIT_API_KEY=
# Numeric ID of the Kit form new subscribers are added to.
KIT_FORM_ID=
