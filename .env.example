# Sanity
# Find these in https://manage.sanity.io (Project settings / API).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
# Optional: server-only token for reading drafts / preview (never expose to the client).
SANITY_API_READ_TOKEN=

# Google Analytics
# GA4 Measurement ID, e.g. G-XXXXXXXXXX. GA only loads after cookie consent.
NEXT_PUBLIC_GA_ID=
